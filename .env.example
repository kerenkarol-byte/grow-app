# Copy this file to .env.local and fill in your values.
# .env.local is gitignored by Vite by default — never commit real keys.

# Spotify podcasts (Client Credentials — no user login needed)
# Create an app at: https://developer.spotify.com/dashboard
# Copy the Client ID and Client Secret shown on the app page.
VITE_SPOTIFY_CLIENT_ID=your_client_id_here
VITE_SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Eventbrite private OAuth token
# Get yours at: https://www.eventbrite.com/platform/api-keys
VITE_EVENTBRITE_TOKEN=your_token_here

# YouTube Data API v3 key
# Get yours at: https://console.cloud.google.com → APIs & Services → Credentials
# Enable the "YouTube Data API v3" for your project first.
VITE_YOUTUBE_API_KEY=your_key_here
