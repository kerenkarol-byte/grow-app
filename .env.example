# Copy this file to .env.local and fill in your values.
# .env.local is gitignored by Vite by default — never commit real keys.

# Listen Notes podcast search API
# Get a free key at: https://www.listennotes.com/api/pricing/
# Free tier: sign up, go to Dashboard → API Keys, copy your key.
VITE_LISTENNOTES_API_KEY=your_key_here

# Meetup events API key / Bearer token
# Option A (legacy key, still works for many accounts):
#   Go to secure.meetup.com/meetup_api/key/ and copy the key shown.
# Option B (OAuth token):
#   Create an OAuth consumer at meetup.com/api/oauth/list/
#   then exchange client credentials for an access token.
VITE_MEETUP_KEY=your_key_here

# YouTube Data API v3 key
# Get yours at: https://console.cloud.google.com → APIs & Services → Credentials
# Enable the "YouTube Data API v3" for your project first.
VITE_YOUTUBE_API_KEY=your_key_here
